{
  "name": "birdminton",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "db:types": "npx supabase gen types typescript --local > src/types/database.types.ts",
    "db:backup": "mkdir -p .backup && pg_dump $DATABASE_URL > .backup/backup-$(date +%Y%m%d-%H%M%S).sql 2>&1 || echo 'pg_dump not available - use Supabase dashboard export'",
    "racket:add": "tsx scripts/add-racket.ts",
    "racket:validate": "tsx scripts/validate-racket.ts",
    "racket:sync": "tsx scripts/sync-supabase.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.2.0",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@tiptap/extension-character-count": "^3.20.5",
    "@tiptap/extension-image": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-table": "^3.20.5",
    "@tiptap/extension-table-cell": "^3.20.5",
    "@tiptap/extension-table-header": "^3.20.5",
    "@tiptap/extension-table-row": "^3.20.5",
    "@tiptap/extension-text-align": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/extension-youtube": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.4",
    "shadcn": "^4.0.2",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
